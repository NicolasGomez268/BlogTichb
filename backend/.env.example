# Django core
DJANGO_SECRET_KEY=replace-with-a-long-random-secret
DJANGO_DEBUG=False
DJANGO_ALLOWED_HOSTS=yourusername.pythonanywhere.com,127.0.0.1,localhost

# CORS (frontend domains allowed to call the API)
DJANGO_CORS_ALLOWED_ORIGINS=https://your-frontend.vercel.app

# CSRF trusted origins (for admin/login forms over HTTPS)
DJANGO_CSRF_TRUSTED_ORIGINS=https://yourusername.pythonanywhere.com,https://your-frontend.vercel.app
